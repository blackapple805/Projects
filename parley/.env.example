# Parley configuration — copy this file to ".env" and fill in ONE provider.
# Every provider below uses the same OpenAI-compatible format, so you only
# change these three values to switch.

# ── Groq (default): free, no credit card, fastest. Get a key at
#    https://console.groq.com/keys
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# ── Google Gemini: most capable free tier (1,500 req/day). Key at
#    https://aistudio.google.com/apikey
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=your-gemini-key
# LLM_MODEL=gemini-2.0-flash

# ── OpenRouter: widest model choice, many ":free" models. Key at
#    https://openrouter.ai/keys
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=your-openrouter-key
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Ollama: fully local, no key, no signup, free forever. Install from
#    https://ollama.com then run:  ollama run llama3.2
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=
# LLM_MODEL=llama3.2

# Optional: change the assistant's personality.
# LLM_SYSTEM_PROMPT=You are Parley, a concise and friendly assistant.

# Optional: web server port (default 5000).
# PORT=5000
